//@version=6
indicator("Swing High/Low Dots - Jestin V James", overlay = true)

// === User Inputs ===
highColor = input.color(color.red, "Swing High Color")
lowColor  = input.color(color.green, "Swing Low Color")

sizeOption = input.string("small", "Dot Size",
     options = ["tiny", "small", "normal", "large", "huge"])

n = input.int(2, "Lookback/Lookahead Bars", minval=1, maxval=20,
     tooltip="Number of bars before and after the pivot candle used for swing detection. Default is 2.")

// === Single Swing Detection (pivot at bar[n], n candles before and after) ===
isSwingLow  = ta.lowest(low,   n)      > low[n]  and ta.lowest(low,   n)[n + 1] > low[n]
isSwingHigh = ta.highest(high, n)      < high[n] and ta.highest(high, n)[n + 1] < high[n]

// === Equal Pair Detection (pair spans bar[n+1] and bar[n]) ===
// Both candles share the same low/high, and it is lower/higher than
// the n candles before the pair and n candles after the pair.
// The circle is placed on the second (last) candle of the pair — bar[n], offset=-n.
isEqualLowPair  = low[n + 1]  == low[n]  and ta.lowest(low,   n)      > low[n]  and ta.lowest(low,   n)[n + 2] > low[n]
isEqualHighPair = high[n + 1] == high[n] and ta.highest(high, n)      < high[n] and ta.highest(high, n)[n + 2] < high[n]

isMarkLow  = isSwingLow  or isEqualLowPair
isMarkHigh = isSwingHigh or isEqualHighPair

// === Plot (editable=false hides from Style panel; display=display.pane hides from status line) ===
plotshape(isMarkLow  and sizeOption == "tiny",   style=shape.circle, location=location.belowbar,  color=lowColor,  size=size.tiny,   offset=-n, editable=false, display=display.pane)
plotshape(isMarkLow  and sizeOption == "small",  style=shape.circle, location=location.belowbar,  color=lowColor,  size=size.small,  offset=-n, editable=false, display=display.pane)
plotshape(isMarkLow  and sizeOption == "normal", style=shape.circle, location=location.belowbar,  color=lowColor,  size=size.normal, offset=-n, editable=false, display=display.pane)
plotshape(isMarkLow  and sizeOption == "large",  style=shape.circle, location=location.belowbar,  color=lowColor,  size=size.large,  offset=-n, editable=false, display=display.pane)
plotshape(isMarkLow  and sizeOption == "huge",   style=shape.circle, location=location.belowbar,  color=lowColor,  size=size.huge,   offset=-n, editable=false, display=display.pane)

plotshape(isMarkHigh and sizeOption == "tiny",   style=shape.circle, location=location.abovebar,  color=highColor, size=size.tiny,   offset=-n, editable=false, display=display.pane)
plotshape(isMarkHigh and sizeOption == "small",  style=shape.circle, location=location.abovebar,  color=highColor, size=size.small,  offset=-n, editable=false, display=display.pane)
plotshape(isMarkHigh and sizeOption == "normal", style=shape.circle, location=location.abovebar,  color=highColor, size=size.normal, offset=-n, editable=false, display=display.pane)
plotshape(isMarkHigh and sizeOption == "large",  style=shape.circle, location=location.abovebar,  color=highColor, size=size.large,  offset=-n, editable=false, display=display.pane)
plotshape(isMarkHigh and sizeOption == "huge",   style=shape.circle, location=location.abovebar,  color=highColor, size=size.huge,   offset=-n, editable=false, display=display.pane)
